@article{abubakarDoesFiscalTightening2020,
  title = {Does Fiscal Tightening (Loosening) Reduce Public Debt?},
  author = {Abubakar, Attahir Babaji},
  year = 2020,
  journal = {African Development Review},
  volume = {32},
  number = {4},
  pages = {528--539},
  issn = {1467-8268},
  doi = {10.1111/1467-8268.12458},
  urldate = {2025-11-10},
  abstract = {This study examined the effect of fiscal tightening and loosening on the public debt of sub-Saharan African (SSA) countries. To achieve this, the study employed a two-step approach. In the first step, the effect of government primary balance on public debt was examined; while in the second step, the primary balance was disaggregated into its surplus and deficit components with the effect of each component on public debt examined. By utilising data covering a panel of 37 SSA countries for the period 2008 to 2017, the study employed the Panel System Generalised Method of Moments (GMM) model for analysis. Estimation results indicated that fiscal tightening (via government surpluses) produces a depressing effect on the stock of public debt while fiscal loosening increases the stock of public debt. Economic growth was also found to be effective in reducing public debt. The study cautions against protracted fiscal tightening due to its potential negative effect on economic growth and social welfare, thereby rendering it counterproductive.},
  langid = {english},
  keywords = {Africa,austerity,deficit,economic growth,fiscal consolidation,government balance,public debt,surplus},
  file = {C\:\\Users\\pltun\\Zotero\\storage\\7RU2F6SM\\Abubakar - 2020 - Does fiscal tightening (loosening) reduce public debt.pdf;C\:\\Users\\pltun\\Zotero\\storage\\9KJ84WHG\\African Development Review - 2020 - Abubakar - Does fiscal tightening  loosening  reduce public debt.pdf;C\:\\Users\\pltun\\Zotero\\storage\\BIR7I3S9\\Austeridade fiscal reduz a dívida pública_ - Abubakar (2020).pdf;C\:\\Users\\pltun\\Zotero\\storage\\X6X2VPDQ\\African Development Review - 2020 - Abubakar - Does fiscal tightening  loosening  reduce public debt.pdf;C\:\\Users\\pltun\\Zotero\\storage\\2285P99F\\deepseek_html_20260501_4ca328 (1).pdf.html;C\:\\Users\\pltun\\Zotero\\storage\\US2NFUQC\\1467-8268.html}
}

