  author = {de Carvalho, Gabriel Augusto and Amaral, Hudson Fernandes and Pinheiro, Juliano Lima and Correia, La{\'i}se Ferraz},
  year = 2021,
  month = jul,
  journal = {Revista Contabilidade \& Finan\c cas},
  volume = {32},
