@misc{bahlTestingFamaFrench2006,
  type = {{SSRN Scholarly Paper}},
  title = {{Testing the Fama and French Three-Factor Model and its Variants for the Indian Stock Returns}},
  author = {Bahl, Bhavna},
  year = 2006,
  month = aug,
  number = {950899},
  address = {Rochester, NY},
  doi = {10.2139/ssrn.950899},
  urldate = {2024-06-18},
  abstract = {Estudo empiricamente o modelo de tr\^es fatores de retornos de a\c c\~oes de Fama e French, juntamente com suas variantes, incluindo o modelo de precifica\c c\~ao de ativos de capital de um fator para 79 a\c c\~oes listadas no \'indice do mercado de a\c c\~oes BSE-100 da \'India. Essas a\c c\~oes de amostra s\~ao divididas em seis carteiras classificadas por tamanho e \'indice de patrim\^onio l\'iquido/valor de mercado. As carteiras de fatores que explicam os retornos s\~ao o fator mercado, fator tamanho (SMB) e fator valor (HML). Encontro fortes evid\^encias do fator mercado em todas as carteiras, sendo considerado o de maior poder explicativo. Os fatores SMB e HML n\~ao podem ser claramente classificados a este respeito. Com base no R{$^2$} ajustado, confirmo que o modelo de tr\^es fatores capta melhor a varia\c c\~ao comum nos retornos das a\c c\~oes do que o CAPM, sendo o R{$^2$} m\'edio ajustado de 87\% para o primeiro modelo e 76\% para o segundo modelo. Realizo ainda um teste conjunto do termo constante nas regress\~oes de carteiras utilizando a estat\'istica de teste GRS, verificando se h\'a retornos anormais que n\~ao s\~ao capturados pelas carteiras de fatores. Utilizando esta estat\'istica, descubro novamente que o modelo de tr\^es factores de Fama e das feiras francesas explica melhor a sec\c c\~ao transversal dos retornos nas carteiras do que as suas variantes e o CAPM. Tamb\'em verifiquei quaisquer efeitos sazonais que pudessem estar presentes na amostra e n\~ao encontrei nenhum.},
  langid = {portuguese},
