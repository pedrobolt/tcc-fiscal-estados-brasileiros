@article{placidoSubstituicaoParadigmasUma2024,
  title = {{Substitui\c c\~ao de paradigmas ? : uma transi\c c\~ao no ensino do modelo IS-LM/AS-AD para o modelo IS-PC-MR}},
  shorttitle = {{Substitui\c c\~ao de paradigmas ?}},
  author = {Pl{\'a}cido, Rodrigo Moses Aguiar},
  year = 2024,
  month = feb,
  urldate = {2024-06-24},
  abstract = {Este trabalho buscou compreender o processo de atualiza\c c\~ao do conte\'udo abarcado nos manuais de macroeconomia de gradua\c c\~ao, dado o desenvolvimento da teoria macroecon\^omica ao longo do tempo. O objetivo geral busca compreender a transi\c c\~ao feita do modelo IS-LM/AS-AD para o modelo IS-PC-MR. Para orientar a investiga\c c\~ao, foi utilizado o arcabou\c co anal\'itico desenvolvido por Thomas Kuhn (2019 [1962]). Por\'em, como n\~ao h\'a consenso na literatura metodol\'ogica em economia sobre a possibilidade de aplica\c c\~ao do arcabou\c co anal\'itico desenvolvido por Kuhn, \'e necess\'aria uma discuss\~ao mais aprofundada a respeito do m\'etodo de investiga\c c\~ao na Ci\^encia Econ\^omica. Desse modo, \'e definido a pergunta de pesquisa, ou seja, se \'e poss\'ivel interpretar o processo de substitui\c c\~ao do modelo padr\~ao de ensino de macroeconomia IS-LM/AS-AD como uma substitui\c c\~ao de paradigmas kuhniano. Sendo assim, para responder de forma apropriada a pergunta de pesquisa, foram determinados tr\^es objetivos espec\'ificos: em primeiro, determinar a possibilidade de aplica\c c\~ao da perspectiva kuhniana na Ci\^encia Econ\^omica; em segundo, determinar a possibilidade de compreender modelos econ\^omicos matem\'aticos como paradigmas macroeconomia; por fim, em terceiro, se \'e poss\'ivel determinar efetivamente a ocorr\^encia da transi\c c\~ao do modelo padr\~ao de ensino. Para responder a pergunta de pesquisa e atingir os objetivos geral e espec\'ificos, foi adotado a t\'ecnica de revis\~ao de literatura, a partir de livros, artigos cient\'ificos e manuais de macroeconomia direcionados para a gradua\c c\~ao. Por fim, dada a an\'alise feita, conclui-se que \'e poss\'ivel determinar efetivamente que h\'a um processo de substitui\c c\~ao do modelo padr\~ao de ensino de teoria macroecon\^omica, que \'e poss\'ivel aplicar o arcabou\c co conceitual kuhniano em Ci\^encia Econ\^omica e que \'e poss\'ivel entender modelos econ\^omicos matem\'aticos como paradigmas de ensino de macroeconomia. Portanto, a transi\c c\~ao do modelo IS-LM/AS-AD pode ser entendida como um processo de substitui\c c\~ao de paradigma.},
  langid = {portuguese},
  annotation = {Accepted: 2024-06-10T11:59:50Z},
  file = {C:\Users\pltun\Zotero\storage\56DGC423\Plácido - 2024 - Substituição de paradigmas   uma transição no en.pdf}
}

