@article{fatas2026,
  title = {Dynamic Effects of Fiscal Rules: {{Do}} Initial Conditions {{Matter}}?},
  shorttitle = {Dynamic Effects of Fiscal Rules},
  author = {Fat{\'a}s, Antonio and Gootjes, Bram and Mawejje, Joseph},
  year = 2026,
